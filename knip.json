{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/cli/*.ts!",
    "src/agents/*.ts!",
    "src/workflows/*.ts!",
    "flue.config.ts",
    "test/*.test.ts"
  ],
  "project": ["src/**/*.ts!", "test/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "treatConfigHintsAsErrors": true
}
