{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/prepare.ts!",
    "src/publish.ts!",
    "src/report-status.ts!",
    "src/check-credentials.ts!",
    "src/agents/*.ts!",
    "src/workflows/*.ts!",
    "flue.config.ts",
    "test/*.test.ts"
  ],
  "project": ["src/**/*.ts!", "!src/dev/**!", "test/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "treatConfigHintsAsErrors": true
}
