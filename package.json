{
  "name": "depvisor",
  "version": "2.4.0",
  "private": true,
  "description": "GitHub Action that reviews and fixes existing Dependabot and Renovate PRs.",
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.ts",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check && pnpm run knip && pnpm test && pnpm run flue:build",
    "flue:build": "flue build --target node",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "knip": "knip && knip --strict",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.9",
    "@types/node": "24.13.3",
    "knip": "6.26.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
